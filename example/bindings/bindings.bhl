import "std/bind"

func RegisterBindings(std.bind.Types types) {

    {
      var fn = std.bind.NewFuncSymbolNative("Trace", types.T("void"),
       [
        std.bind.NewFuncArgSymbol("str", types.T("string"))
       ]
      )
      types.ns.Define(fn)
    }

    {
      var fn = std.bind.NewFuncSymbolNative("Rand", types.T("float"),
      []
      )
      types.ns.Define(fn)
    }
}
