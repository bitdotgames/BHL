{
  "name": "bhl",
  "displayName": "BHL",
  "version": "0.0.7",
  "description": "BHL language support",
  "author": "BHL",
  "engines": {
    "vscode": "^1.79.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:bhl"
  ],
  "main": "./out/extension",
  "contributes": {
    "languages": [
      {
        "id": "bhl",
        "aliases": ["BHL", "bhl"],
        "extensions": [".bhl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "bhl.reload",
        "title": "BHL: Reload Project"
      }
    ],
    "configuration": {
      "title": "BHL",
      "properties": {
        "bhl.executablePath": {
          "type": "string",
          "default": "",
          "description": "Path to the bhl executable. Defaults to 'bhl' on PATH."
        },
        "bhl.logFile": {
          "type": "string",
          "default": "",
          "description": "Path to the LSP log file. If set, passes --log-file=<path> to the server."
        },
        "bhl.forceRebuild": {
          "type": "boolean",
          "default": false,
          "description": "Force full rebuild on startup by setting BHL_REBUILD=1."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.79.0",
    "@types/node": "^16.18.0",
    "typescript": "^4.9.0"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}
