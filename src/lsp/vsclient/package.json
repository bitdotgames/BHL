{
  "name": "bhl",
  "displayName": "BHL",
  "publisher": "vscodebhl",
  "version": "0.0.11",
  "repository": {
    "type": "git",
    "url": "https://github.com/bitdotgames/BHL"
  },
  "description": "BHL language support",
  "author": "BHL",
  "engines": {
    "vscode": "^1.79.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:bhl"
  ],
  "main": "./out/extension",
  "contributes": {
    "languages": [
      {
        "id": "bhl",
        "aliases": ["BHL", "bhl"],
        "extensions": [".bhl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "bhl.reload",
        "title": "BHL: Reload Project"
      }
    ],
    "semanticTokenScopes": [
      {
        "scopes": {
          "class": ["entity.name.type.class"],
          "function": ["entity.name.function"],
          "variable": ["variable.other.readwrite"],
          "number": ["constant.numeric"],
          "string": ["string.quoted.double"],
          "type": ["entity.name.type"],
          "keyword": ["keyword.control"],
          "property": ["variable.other.property"],
          "operator": ["keyword.operator"],
          "parameter": ["variable.parameter"]
        }
      }
    ],
    "configurationDefaults": {
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "*.deprecated": {
            "strikethrough": true,
            "opacity": 0.6
          }
        }
      }
    },
    "configuration": {
      "title": "BHL",
      "properties": {
        "bhl.executablePath": {
          "type": "string",
          "default": "",
          "description": "Path to the bhl executable. Defaults to 'bhl' on PATH."
        },
        "bhl.logFile": {
          "type": "string",
          "default": "",
          "description": "Path to the LSP log file. If set, passes --log-file=<path> to the server."
        },
        "bhl.forceRebuild": {
          "type": "boolean",
          "default": false,
          "description": "Force full rebuild on startup by setting BHL_REBUILD=1."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.79.0",
    "@types/node": "^16.18.0",
    "typescript": "^4.9.0"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}
