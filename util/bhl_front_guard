#!/usr/bin/env python3
# Wraps .cs files in a directory with #if (BHL_FRONT || BHL_PARSER) / #endif guards.
# Skips files that already have the guard.
# Usage: bhl_front_guard <directory>

import os, sys

GUARD = '#if (BHL_FRONT || BHL_PARSER)'

def guard(path):
    with open(path) as f:
        src = f.read()
    if src.startswith(GUARD):
        return
    lines = src.splitlines(keepends=True)
    if GUARD in src:
        lines = [l for l in lines if l.strip() != GUARD]
    lines.insert(0, GUARD + '\n\n')
    if '\n#endif\n' not in src:
        lines.append('\n#endif\n')
    with open(path, 'w') as f:
        f.writelines(lines)
    print(f'  guarded {os.path.basename(path)}')

if len(sys.argv) < 2:
    print('Usage: bhl_front_guard <directory>', file=sys.stderr)
    sys.exit(1)

d = sys.argv[1]
files = sorted(f for f in os.listdir(d) if f.endswith('.cs'))
for name in files:
    guard(os.path.join(d, name))
print(f'Done ({len(files)} files).')
