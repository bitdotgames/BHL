#!/usr/bin/env python3
# Wraps .cs files in a directory with #if BHL_FRONT / #endif guards.
# Skips files that already have the guard.
# Usage: bhl_front_guard <directory>

import os, sys

def guard(path):
    with open(path) as f:
        src = f.read()
    if '#if BHL_FRONT' in src:
        return
    lines = src.splitlines(keepends=True)
    insert_at = 0
    for i, line in enumerate(lines):
        if line.startswith('using '):
            insert_at = i + 1
    lines.insert(insert_at, '\n#if BHL_FRONT\n')
    lines.append('\n#endif\n')
    with open(path, 'w') as f:
        f.writelines(lines)
    print(f'  guarded {os.path.basename(path)}')

if len(sys.argv) < 2:
    print('Usage: bhl_front_guard <directory>', file=sys.stderr)
    sys.exit(1)

d = sys.argv[1]
files = sorted(f for f in os.listdir(d) if f.endswith('.cs'))
for name in files:
    guard(os.path.join(d, name))
print(f'Done ({len(files)} files).')
