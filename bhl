#!/bin/bash

set -Eeuo pipefail

SCRIPT_DIR="$(
  cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1
  pwd -P
)"

PROJECT_FILE="$SCRIPT_DIR/bhl.csproj"
VERSION_FILE="$SCRIPT_DIR/src/vm/version.cs"
BHL_DLL="$SCRIPT_DIR/build/bhl/Release/net8.0/bhl.dll"

needs_rebuild=false

if [[ ! -f "$BHL_DLL" ]]; then
  needs_rebuild=true
elif [[ "$BHL_DLL" -ot "$VERSION_FILE" ]]; then
  needs_rebuild=true
elif [[ -n "${BHL_REBUILD:-}" ]]; then
  needs_rebuild=true
fi

VERBOSITY=""
if [[ -n "${BHL_SILENT:-}" ]]; then
  VERBOSITY="--verbosity q -nologo"
fi

if [[ "$needs_rebuild" == true ]]; then
  (
    cd "$SCRIPT_DIR"

    # Best-effort clean; do not fail the whole script if clean fails.
    dotnet clean "$PROJECT_FILE" $VERBOSITY || true

    dotnet publish "$PROJECT_FILE" $VERBOSITY
  )

  # Refresh timestamp if the publish created the DLL.
  [[ -f "$BHL_DLL" ]] && touch "$BHL_DLL"
fi

exec dotnet "$BHL_DLL" "$@"
